Apr 02 12:34:57.000000 172.28.0.2 postgres[84]: [38-1] 2026-04-02 12:34:57.995 UTC [84] 00000: db=app_db,user=postgres,app=psql,client=[local] LOG:  duration: 0.583 ms  statement: CREATE OR REPLACE FUNCTION check_order_integrity(p_order_id INTEGER)
Apr 02 12:34:57.000000 172.28.0.2 postgres[84]: [38-2] 	RETURNS BOOLEAN AS $$
Apr 02 12:34:57.000000 172.28.0.2 postgres[84]: [38-3] 	DECLARE
Apr 02 12:34:57.000000 172.28.0.2 postgres[84]: [38-4] 	    v_amount DECIMAL;
Apr 02 12:34:57.000000 172.28.0.2 postgres[84]: [38-5] 	    v_user_id INTEGER;
Apr 02 12:34:57.000000 172.28.0.2 postgres[84]: [38-6] 	    v_status VARCHAR;
Apr 02 12:34:57.000000 172.28.0.2 postgres[84]: [38-7] 	BEGIN
Apr 02 12:34:57.000000 172.28.0.2 postgres[84]: [38-8] 	    SELECT amount, user_id, status INTO v_amount, v_user_id, v_status
Apr 02 12:34:57.000000 172.28.0.2 postgres[84]: [38-9] 	    FROM orders WHERE id = p_order_id;
Apr 02 12:34:57.000000 172.28.0.2 postgres[84]: [38-10] 	
Apr 02 12:34:57.000000 172.28.0.2 postgres[84]: [38-11] 	    IF NOT FOUND THEN
Apr 02 12:34:57.000000 172.28.0.2 postgres[84]: [38-12] 	        RAISE WARNING 'Commande #% introuvable lors de la vérification d''intégrité', p_order_id;
Apr 02 12:34:57.000000 172.28.0.2 postgres[84]: [38-13] 	        RETURN FALSE;
Apr 02 12:34:57.000000 172.28.0.2 postgres[84]: [38-14] 	    END IF;
Apr 02 12:34:57.000000 172.28.0.2 postgres[84]: [38-15] 	
Apr 02 12:34:57.000000 172.28.0.2 postgres[84]: [38-16] 	    IF v_amount > 1000 THEN
Apr 02 12:34:57.000000 172.28.0.2 postgres[84]: [38-17] 	        RAISE WARNING 'Montant élevé détecté sur commande #%: % EUR — vérification manuelle requise', p_order_id, v_amount;
Apr 02 12:34:57.000000 172.28.0.2 postgres[84]: [38-18] 	    END IF;
Apr 02 12:34:57.000000 172.28.0.2 postgres[84]: [38-19] 	
Apr 02 12:34:57.000000 172.28.0.2 postgres[84]: [38-20] 	    IF v_status = 'pending' AND v_amount > 500 THEN
Apr 02 12:34:57.000000 172.28.0.2 postgres[84]: [38-21] 	        RAISE NOTICE 'Commande #% en attente avec montant % EUR', p_order_id, v_amount;
Apr 02 12:34:57.000000 172.28.0.2 postgres[84]: [38-22] 	    END IF;
Apr 02 12:34:57.000000 172.28.0.2 postgres[84]: [38-23] 	
Apr 02 12:34:57.000000 172.28.0.2 postgres[84]: [38-24] 	    RETURN TRUE;
Apr 02 12:34:57.000000 172.28.0.2 postgres[84]: [38-25] 	END;
Apr 02 12:34:57.000000 172.28.0.2 postgres[84]: [38-26] 	$$ LANGUAGE plpgsql;
